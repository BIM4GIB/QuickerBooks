# Intuit Developer App credentials
# Create an app at https://developer.intuit.com/app/developer/dashboard
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here

# Optional: use sandbox environment (default: false)
QBO_SANDBOX=false

# Optional: OAuth redirect URI (default: http://localhost:9876/callback)
QBO_REDIRECT_URI=http://localhost:9876/callback
